#!/usr/bin/env bash

# Locks the system using hyprlock, while ensuring:
# - keyboard layout reset
# - 1Password lock
# - screensaver shutdown

set -euo pipefail

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 >/dev/null 2>&1 || true

# Ensure 1Password is locked
1password --lock >/dev/null 2>&1 || true

# Avoid running screensaver when locked
pkill -f 'org.omadora.screensaver' >/dev/null 2>&1 || true

# Small wait for window closing animations to finish
sleep 0.1

# Lock screen if not already locked
if ! pgrep -x hyprlock >/dev/null; then
  exec hyprlock
fi
