#!/usr/bin/env bash

set -euo pipefail

ROOT="${OMADORA_PATH:-$HOME/.local/share/omadora}"
LIBEXEC="$ROOT/libexec"

die() {
  printf 'omactl: %s\n' "$*" >&2
  exit 1
}

cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  echo "usage: omactl <command> [args]"
  echo
  echo "commands:"

  for f in "$LIBEXEC"/omactl-*; do
    [[ -x "$f" ]] || continue
    echo "  ${f##*/omactl-}"
  done
  ;;

*)
  shift || true

  subcommand="$LIBEXEC/omactl-$cmd"

  [[ -x "$subcommand" ]] || die "unknown command: $cmd"

  exec "$subcommand" "$@"
  ;;
esac
