#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# ----------------------------
# Usage
# ----------------------------
usage() {
  local f

  cat <<'EOF'
Usage:
  omactl <command>

Commands:
EOF

  for f in "$OMADORA_LIBEXEC_DIR"/omactl-*; do
    [[ -x "$f" ]] || continue
    printf '  %s\n' "${f##*/omactl-}"
  done

  printf '\n'
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  usage
  ;;

*)
  shift

  readonly subcommand="$OMADORA_LIBEXEC_DIR/omactl-$cmd"

  if [[ ! -x "$subcommand" ]]; then
    usage >&2
    fatal "unknown command: $cmd"
  fi

  exec "$subcommand" "$@"
  ;;
esac
