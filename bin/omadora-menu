#!/bin/bash

# Launch the Omadora Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/omadora/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-a" "$index")
    fi
  fi

  echo -e "$options" | wofi --dmenu --width 320 --lines 16 -p "$prompt‚Ä¶" "${args[@]}"
}

terminal() {
  alacritty --class=org.omadora.terminal -e "$@"
}

present_terminal() {
  omadora-launch-floating-terminal-with-presentation "$1"
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  omadora-launch-editor "$1"
}

show_learn_menu() {
  case $(menu "Learn" "ÔĄú  Keybindings\nÔźÖ  Omadora\nÔźÖ  Omarchy\nÔćô  Hyprland\nÔĆä  Fedora\nůį£á  Arch\nÓöģ  Neovim\nůĪÜÉ  Bash") in
  *Keybindings*) omadora-menu-keybindings ;;
  *Omadora*) omadora-launch-webapp "https://github.com/elpritchos/omadora" ;;
  *Omarchy*) omadora-launch-webapp "https://learn.omacom.io/2/the-omarchy-manual" ;;
  *Hyprland*) omadora-launch-webapp "https://wiki.hypr.land" ;;
  *Fedora*) omadora-launch-webapp "https://docs.fedoraproject.org" ;;
  *Arch*) omadora-launch-webapp "https://wiki.archlinux.org" ;;
  *Neovim*) omadora-launch-webapp "https://neovim.io/doc/user/quickref.html" ;;
  *Bash*) omadora-launch-webapp "https://devhints.io/bash" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ÔÄį  Capture\nůįĒé  Toggle") in
  *Capture*) show_capture_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "ÔÄį  Screenshot\nÔÄĹ  Screenrecord\nůįÉČ  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "ÔÄį  Snap with Editing\nÔÄį  Straight to Clipboard") in
  *Editing*) omadora-cmd-screenshot smart ;;
  *Clipboard*) omadora-cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

show_screenrecord_menu() {
  case $(menu "Screenrecord" "ÔÄĹ  Region\nÔÄĹ  Region + Audio\nÔÄĹ  Display\nÔÄĹ  Display + Audio") in
  *"Region + Audio"*) omadora-cmd-screenrecord region audio ;;
  *Region*) omadora-cmd-screenrecord ;;
  *"Display + Audio"*) omadora-cmd-screenrecord output audio ;;
  *Display*) omadora-cmd-screenrecord output ;;
  *) show_capture_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "ůĪĄĄ  Screensaver\nůįĒé  Nightlight\nůĪęĖ  Idle Lock\nůįćú  Top Bar") in
  *Screensaver*) omadora-toggle-screensaver ;;
  *Nightlight*) omadora-toggle-nightlight ;;
  *Idle*) omadora-toggle-idle ;;
  *Bar*) omactl workspace toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "ůįłĆ  Theme\nÓôô  Font\nÔÄĺ  Background\nÔćô  Hyprland\nůĪĄĄ  Screensaver\nÓ©ī  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) omactl theme bg-next ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.config/omadora/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/omadora/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  theme=$(menu "Theme" "$(omactl theme list)" "" "$(omactl theme current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    omactl theme set "$theme"
  fi
}

show_font_menu() {
  theme=$(menu "Font" "$(omadora-font-list)" "-w 350" "$(omadora-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    omadora-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="Óėł  Audio\nÔáę  Wifi\nůįāĮ  Bluetooth\nůĪźč  Power Profile\nůįćĻ  Monitors"
  [ -f ~/.config/hypr/bindings.conf ] && options="$options\nÔĄú  Keybindings"
  [ -f ~/.config/hypr/input.conf ] && options="$options\nůįćĹ  Input"
  options="$options\nůįĪĒ  DNS\nÓėē  Config"

  case $(menu "Setup" "$options") in
  *Audio*) omadora-launch-audio ;;
  *Wifi*) omadora-launch-wifi ;;
  *Bluetooth*) omadora-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *DNS*) present_terminal omadora-setup-dns ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(omadora-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    omadora-powerprofiles-set "$profile"
  fi
}

show_setup_config_menu() {
  case $(menu "Setup" "Ôćô  Hyprland\nÔćô  Hypridle\nÔćô  Hyprlock\nÔćô  Hyprsunset\nůįĆß  Wofi\nůįćú  Waybar\nůįěÖ  XCompose") in
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && omadora-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && omadora-restart-hyprsunset ;;
  *Wofi*) open_in_editor ~/.config/wofi/config ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omadora-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && omadora-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "ÔĆä  Package\nÔČ®  Web App\nÔíČ  TUI\nÓĮŹ  Style") in
  *Package*) terminal omadora-pkg-install ;;
  *Web*) present_terminal omadora-webapp-install ;;
  *TUI*) present_terminal omadora-tui-install ;;
  *Style*) show_install_style_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "ůįłĆ  Theme\nÔÄĺ  Background") in
  *Theme*) present_terminal 'omactl theme add "$(gum input --placeholder="https://github.com/..." --header="Install user theme from repo URL:")"' ;;
  *Background*)
    theme="$(omactl theme current)"
    if [ -z "$theme" ]; then
      notify-send "No active theme" "Set a theme before adding backgrounds"
    else
      dir="$HOME/.config/omadora/backgrounds/$theme"
      mkdir -p "$dir" && nautilus "$dir"
    fi
    ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  case $(menu "Remove" "ÔĆä  Package\nÔČ®  Web App\nÔíČ  TUI\nůįłĆ  Theme") in
  *Package*) terminal omadora-pkg-remove ;;
  *Web*) present_terminal omadora-webapp-remove ;;
  *TUI*) present_terminal omadora-tui-remove ;;
  *Theme*) present_terminal 'omactl theme remove "$(omactl theme list-user | gum choose --header="Remove user theme:")"' ;;
  *) show_main_menu ;;
  esac
}

show_update_menu() {
  case $(menu "Update" "ÔĆä  Omadora\nÓėē  Config\nůįłĆ  Theme\nÓģĘ  Process\nůįáÖ  Hardware\nÓ¨Ď  Password\nÓéÉ  Timezone") in
  *Omadora*) present_terminal 'omactl update all' ;;
  *Config*) show_update_config_menu ;;
  *Theme*) present_terminal 'omactl theme update "$(omactl theme list-user | gum choose --header="Update user theme:")"' ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Timezone*) present_terminal omadora-tz-select ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_process_menu() {
  case $(menu "Restart" "Ôćô  Hypridle\nÔćô  Hyprsunset\nůįćú  Waybar") in
  *Hypridle*) omadora-restart-hypridle ;;
  *Hyprsunset*) omadora-restart-hyprsunset ;;
  *Waybar*) omadora-restart-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "Ôćô  Hyprland\nÔćô  Hypridle\nÔćô  Hyprlock\nÔćô  Hyprsunset\nůĪ£ī  Plymouth\nůįĆß  Wofi\nůįćú  Waybar") in
  *Hyprland*) present_terminal omadora-refresh-hyprland ;;
  *Hypridle*) present_terminal omadora-refresh-hypridle ;;
  *Hyprlock*) present_terminal omadora-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal omadora-refresh-hyprsunset ;;
  *Plymouth*) present_terminal omadora-refresh-plymouth ;;
  *Wofi*) present_terminal omadora-refresh-wofi ;;
  *Waybar*) present_terminal omadora-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "Óėł  Audio\nůĪöĺ  Wi-Fi\nůįāĮ  Bluetooth") in
  *Audio*) present_terminal omadora-restart-pipewire ;;
  *Wi-Fi*) present_terminal omadora-restart-wifi ;;
  *Bluetooth*) present_terminal omadora-restart-bluetooth ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "Ó¨Ď  Drive Encryption\nÓ¨Ď  User") in
  *Drive*) present_terminal omadora-drive-set-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_system_menu() {
  case $(menu "System" "ÔÄ£  Lock\nůĪĄĄ  Screensaver\nÔćô  Logout\nůįúČ  Reboot\nůįź•  Shutdown") in
  *Lock*) omactl system lock ;;
  *Screensaver*) omactl system screensaver ;;
  *Logout*) omactl system logout ;;
  *Reboot*) omactl system reboot ;;
  *Shutdown*) omactl system shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "ůįÄĽ  Apps\nůįßĎ  Learn\nůĪďě  Trigger\nÓĮŹ  Style\nÓėē  Setup\nůįČČ  Install\nůį≠Ć  Remove\nÔÄ°  Update\nÓ©ī  About\nÔÄĎ  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) wofi --show drun --lines 8 -p "Launch‚Ä¶" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) omadora-launch-about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omadora/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  pkill wofi || go_to_menu "$1"
else
  pkill wofi || show_main_menu
fi
