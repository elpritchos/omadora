#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-system"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# TODO: Remove this comment
# System: reboot/shutdown/lock/power-profile/timezone/status   install/remove packages

# ----------------------------
# Usage
# ----------------------------
usage() {
  cat <<'EOF'
Usage:
  omactl system <command>

Commands:
  lock                 Start the screen lock
  logout               Logout of the current session
  reboot               Reboot the system
  shutdown             Shutdown the system
  screensaver          Start the screensaver

EOF
}

# ----------------------------
# Completion
# ----------------------------
__complete() {
  local comp_words=("$@")
  local cmd="${comp_words[0]:-}"

  case "$cmd" in
  lock | logout | reboot | shutdown | screensaver)
    ;;

  *)
    compgen -W "lock logout reboot shutdown screensaver" -- "$cmd"
    ;;
  esac
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  usage
  ;;

lock)
  loginctl lock-session
  ;;

logout)
  uwsm stop
  ;;

reboot)
  systemctl reboot --no-wall
  ;;

shutdown)
  systemctl poweroff --no-wall
  ;;

screensaver)
  omadora-launch-screensaver
  ;;

__complete)
  shift
  __complete "$@"
  ;;

*)
  usage >&2
  printf 'ERROR: unknown command: %s\n' "$cmd" >&2
  exit 2
  ;;
esac
