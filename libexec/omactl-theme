#!/usr/bin/env bash
set -Eeuo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

# Theme

# ----------------------------
# Usage
# ----------------------------
usage() {
  cat <<'EOF'
Usage:
  omactl theme <command>

Commands:
  list                 List all themes
  list-user            List user-installed themes
  current              Show current theme
  set <name>           Apply a theme
  add <repo-url>       Install a theme from git
  remove <name>        Remove a user-installed theme
  update <name>        Update an installed theme
  bg-next              Cycle to next background
  bg-add <image-path>  Add a background image

EOF
}

# ----------------------------
# Completion
# ----------------------------
__complete() {
  local comp_words=("$@")

  local cmd="${comp_words[0]:-}"
  local cur=""

  if ((${#comp_words[@]})); then
    cur="${comp_words[${#comp_words[@]} - 1]}"
  fi

  case "$cmd" in
  list | list-user | current | add | bg-next)
    ;;

  set | remove | update)
    if [[ ${#comp_words[@]} -eq 2 ]]; then
      local fn="theme_list_user"
      [[ "$cmd" == "set" ]] && fn="theme_list_all"

      mapfile -t themes < <("$fn")

      compgen -W "$(printf '%s\n' "${themes[@]}")" -- "$cur"
    fi
    ;;

  bg-install)
    if [[ ${#comp_words[@]} -eq 2 ]]; then
      compgen -f -- "$cur"
    fi
    ;;

  bg-remove)
    if [[ ${#comp_words[@]} -eq 2 ]]; then
      current_theme_name="$(theme_current)" || return

      mapfile -t backgrounds < <(
        theme_list_backgrounds "$current_theme_name"
      )

      compgen -W "$(printf '%s\n' "${backgrounds[@]}")" -- "$cur"
    fi
    ;;

  *)
    compgen -W "list list-user current set add remove update bg-next bg-install bg-remove" -- "$cmd"
    ;;
  esac
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  usage
  ;;

list)
  theme_list_all || die "failed to list themes"
  ;;

list-user)
  theme_list_user || die "failed to list user themes"
  ;;

current)
  theme_current || die "failed to get current theme"
  ;;

set)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-set" "$@"
  ;;

add)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-install" "$@"
  ;;

remove)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-remove" "$@"
  ;;

update)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-update" "$@"
  ;;

bg-next)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-bg-next" "$@"
  ;;

bg-install)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-bg-install" "$@"
  ;;

bg-remove)
  shift
  exec_cmd "$OMADORA_LIBEXEC_DIR/omadora-theme-bg-remove" "$@"
  ;;

__complete)
  shift
  __complete "$@"
  ;;

*)
  usage >&2
  error "unknown command: $cmd"
  exit 2
  ;;
esac
