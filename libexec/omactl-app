#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-app"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# ----------------------------
# Usage
# ----------------------------
usage() {
  cat <<'EOF'
Usage:
  omactl app <command>

Commands:

EOF
}

# ----------------------------
# Completion
# ----------------------------
__complete() {
  local comp_words=("$@")
  local cmd="${comp_words[0]:-}"

  case "$cmd" in
  *)
    compgen -W "" -- "$cmd"
    ;;
  esac
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  usage
  ;;

__complete)
  shift
  __complete "$@"
  ;;

*)
  usage >&2
  printf 'ERROR: unknown command: %s\n' "$cmd" >&2
  exit 2
  ;;
esac
