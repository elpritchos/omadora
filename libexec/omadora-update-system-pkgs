#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-update"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

require_cmd dnf5

log_info "Updating system packages"

sudo dnf5 --refresh makecache ||
  fatal "failed to update cache"

sudo dnf5 upgrade -y ||
  fatal "failed to upgrade system packages"

# Fedora: use dnf needs-restarting to detect if a reboot is recommended/required.
# Non-zero exit status indicates a reboot is needed.
if ! sudo dnf needs-restarting >/dev/null 2>&1; then
  touch /run/reboot-required
fi
