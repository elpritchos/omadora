#!/usr/bin/env bash

set -euo pipefail

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/omadora"
# shellcheck source=../lib/theme.sh
source "$DATA_DIR/lib/theme.sh"

current_theme_name=$(theme_current) || exit 1

mapfile -d '' -t backgrounds < <(find -L "${OMADORA_USER_BACKGROUNDS_DIR}/${current_theme_name}/" "${OMADORA_CURRENT_THEME_DIR}/backgrounds" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
total=${#backgrounds[@]}

if [[ $total -eq 0 ]]; then
  rm -f "$OMADORA_CURRENT_BACKGROUND_LINK"
  systemctl --user restart hyprpaper.service
else
  # Get current background from symlink
  if [[ -L "$OMADORA_CURRENT_BACKGROUND_LINK" ]]; then
    current_background=$(readlink "$OMADORA_CURRENT_BACKGROUND_LINK")
  else
    # Default to first background if no symlink exists
    current_background=""
  fi

  # Find current background index
  index=-1
  for i in "${!backgrounds[@]}"; do
    if [[ "${backgrounds[$i]}" == "$current_background" ]]; then
      index=$i
      break
    fi
  done

  # Get next background (wrap around)
  if [[ $index -eq -1 ]]; then
    # Use the first background when no match was found
    new_background="${backgrounds[0]}"
  else
    next_index=$(((index + 1) % total))
    new_background="${backgrounds[$next_index]}"
  fi

  # Set new background symlink
  ln -nsf "$new_background" "$OMADORA_CURRENT_BACKGROUND_LINK"

  # Update the background
  hyprctl hyprpaper wallpaper ,"$OMADORA_CURRENT_BACKGROUND_LINK"
fi
