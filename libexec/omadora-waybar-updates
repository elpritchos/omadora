#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

STATE_FILE="${OMADORA_STATE_HOME}/update/state.json"

if ! jq empty "$STATE_FILE" >/dev/null 2>&1; then
  exit 0
fi

jq -c '
def update_section:
  [
    "Updates:",
    (.updates.dnf.count | tostring + " dnf"),
    (.updates.flatpak.count | tostring + " flatpak"),
    (.updates.cargo.count | tostring + " cargo"),
    (.updates.firmware.count | tostring + " firmware"),
    ""
  ];

def advisory_section:
  [
    "DNF Advisories:",
    (.advisories.dnf.security | tostring + " security"),
    (.advisories.dnf.bugfix | tostring + " bugfix"),
    (.advisories.dnf.enhancement | tostring + " enhancement"),
    (.advisories.dnf.other | tostring + " other"),
    ""
  ];

def full_summary:
  (update_section + advisory_section)
  | join("\n");

if .restart_required then
  {
    text: (.updates.total | tostring),
    alt: "restart-required",
    tooltip: "Restart required\n\n" + full_summary,
    class: ["restart-required"]
  }

elif .updates.total > 0 then
  {
    text: (.updates.total | tostring),

    alt:
      (if .advisories.dnf.security > 0
       then "security"
       else "updates"
       end),

    tooltip:
      (.updates.total | tostring)
      + " Updates Available\n\n"
      + full_summary,

    class:
      (if .advisories.dnf.security > 0
       then ["updates", "security"]
       else ["updates"]
       end)
  }

else
  {
    text: "",
    alt: "updated",
    tooltip: "System fully updated",
    class: ["updated"]
  }

end
' "$STATE_FILE"
