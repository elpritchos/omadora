#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-update"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/update.sh
source "$OMADORA_LIB_DIR/update.sh"

# shellcheck source=lib/state.sh
source "$OMADORA_LIB_DIR/state.sh"

require_cmd gum

# -----------------------------------------------------------------------------
# Confirmation
# -----------------------------------------------------------------------------
confirm() {
  gum confirm \
    --prompt.foreground 7 \
    --selected.foreground 0 \
    --selected.background 4 \
    --unselected.foreground 7 \
    --unselected.background 0 \
    "$1"
}

update_confirm() {
  gum style \
    --border normal \
    --border-foreground 4 \
    --padding "1 2" \
    "Ready to update?" \
    "" \
    "The following updates will occur:" \
    "  • Omadora" \
    "  • System packages" \
    "  • Flatpaks" \
    "  • Cargo-installed binaries" \
    "  • Firmware" \
    "" \
    "• Do not interrupt the update once it starts!" \
    "• Ensure you are connected to power or have sufficient battery."

  confirm "Continue with update?"
}

# -----------------------------------------------------------------------------
# Sudo
# -----------------------------------------------------------------------------

sudo_keepalive() {
  sudo -v || return 1

  (
    while true; do
      sleep 60

      # exit if parent dies
      kill -0 "$PPID" || exit

      # refresh timestamp without triggering auth
      sudo -n true
    done
  ) &
}

# -----------------------------------------------------------------------------
# Cleanup
# -----------------------------------------------------------------------------

cleanup() {
  local exit_code=$?

  if [[ -n "${sudo_pid:-}" ]]; then
    kill "$sudo_pid" 2>/dev/null || true
  fi

  hyprctl dispatch tagwindow -- -noidle >/dev/null 2>&1 || true

  state_clear "update-running" || true

  exit "$exit_code"
}

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

print_step() {
  printf '\n\e[32m%s\e[0m\n' "$1"
}

# -----------------------------------------------------------------------------
# Update
# -----------------------------------------------------------------------------

update_perform() {
  log_info "Starting update"

  state_set "update-running"

  hyprctl dispatch tagwindow +noidle >/dev/null 2>&1 || true

  print_step "Updating git..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-git"

  print_step "Running migrations..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-migrate"

  print_step "Updating system packages..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-system-pkgs"

  print_step "Updating cargo packages..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-cargo"

  print_step "Updating flatpaks..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-flatpak"

  print_step "Updating firmware..."
  "$OMADORA_LIBEXEC_DIR/omadora-update-firmware"

  # TODO: reimplement hooks
  #log_info "Running post-update hooks"
  #omadora-hook post-update

  log_info "Update complete"
}

# -----------------------------------------------------------------------------
# State Refresh
# -----------------------------------------------------------------------------

update_state_refresh() {
  print_step "Refreshing update state..."

  if ! flock -u 9; then
    log_debug "Could not drop update lock"
    printf "Could not drop update lock. Skipping.\n"
    return 0
  fi

  if "$OMADORA_LIBEXEC_DIR/systemd/omadora-update-check" >/dev/null 2>&1; then
    printf "Update state refreshed.\n"
  else
    printf "Failed to refresh update state. Skipped.\n"
  fi
}

# -----------------------------------------------------------------------------
# Reboot/Restart Check
# -----------------------------------------------------------------------------

update_restart_check() {
  # TODO: check uwsm stop/reboot correctness
  if [[ -f "/run/reboot-required" ]]; then
    printf '\n'
    confirm "Updates require reboot. Ready?" && systemctl reboot --no-wall
    exit 0
  fi

  if state_exists "relaunch-required"; then
    printf '\n'
    confirm "Updates require Hyprland relaunch. Ready?" && uwsm stop
    exit 0
  fi
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

trap cleanup EXIT

if [[ "${1:-}" != "-y" ]]; then
  update_confirm || {
    log_info "Update cancelled by user"
    exit 0
  }
fi

sudo_keepalive
sudo_pid=$!

update_dirs_init ||
  fatal "failed to initialize update dirs"

exec 9>"$OMADORA_UPDATE_LOCK_FILE"

flock -n 9 ||
  fatal "another update operation is already running"

update_perform

update_state_refresh

print_step "Update complete."

update_restart_check
