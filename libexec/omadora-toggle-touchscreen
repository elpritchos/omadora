#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Enable, disable, or toggle the touch functionality of the screen

STATE_CONF="$HOME/.local/state/omadora/toggles/hypr/touchscreen-disabled.conf"

device="$(omadora_run omadora-hw-touchscreen)"

if [[ -z $device ]]; then
  echo "No touchscreen device found" >&2
  exit 1
fi

enable() {
  hyprctl keyword "device[$device]:enabled" true >/dev/null
  rm -f "$STATE_CONF"
  notify-send -u low "󰆽    Touchscreen enabled"
}

disable() {
  hyprctl keyword "device[$device]:enabled" false >/dev/null
  mkdir -p "$(dirname "$STATE_CONF")"
  printf 'device {\n    name = %s\n    enabled = false\n}\n' "$device" >"$STATE_CONF"
  notify-send -u low "󰆽    Touchscreen disabled"
}

case "${1:-toggle}" in
on) enable ;;
off) disable ;;
toggle) if [[ -f $STATE_CONF ]]; then enable; else disable; fi ;;
esac
