#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

theme_name="${1:-}"

[[ -n "$theme_name" ]] ||
  die "missing theme name"

theme_path="${OMADORA_USER_THEMES_DIR}/$theme_name"

[[ -d "$theme_path" ]] ||
  die "theme not found: $theme_name"

[[ -d "$theme_path/.git" ]] ||
  die "theme is not a git repository: $theme_name"

info "Updating theme: $theme_name"

git -C "$theme_path" pull --ff-only ||
  die "failed to update theme: $theme_name"

"$OMADORA_LIBEXEC_DIR/omadora-theme-set" "$theme_name" ||
  die "failed to apply updated theme"

info "Updated theme: $theme_name"
