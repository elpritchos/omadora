#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

theme_name="${1:-}"

[[ -n "$theme_name" ]] || {
  echo "Error: Missing theme name." >&2
  exit 1
}

theme_path="${OMADORA_USER_THEMES_DIR}/$theme_name"

if [ ! -d "$theme_path" ]; then
  echo "Error: Theme '$theme_name' not found." >&2
  exit 1
fi

if [ ! -d "$theme_path/.git" ]; then
  echo "Error: Failed to update theme '$theme_name'. Not a git repository." >&2
  exit 1
fi

if ! git -C "$theme_path" pull --ff-only; then
  echo "Error: Failed to update theme '$theme_name'. Please resolve any conflicts manually." >&2
  exit 1
fi
