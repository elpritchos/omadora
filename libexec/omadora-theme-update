#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-theme"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

theme_name="${1:-}"

[[ -n "$theme_name" ]] ||
  fatal "missing theme name"

theme_path="${OMADORA_USER_THEMES_DIR}/$theme_name"

[[ -d "$theme_path" ]] ||
  fatal "theme not found: $theme_name"

[[ -d "$theme_path/.git" ]] ||
  fatal "theme is not a git repository: $theme_name"

log_info "Updating theme: $theme_name"

git -C "$theme_path" pull --ff-only ||
  fatal "failed to update theme: $theme_name"

"$OMADORA_LIBEXEC_DIR/omadora-theme-set" "$theme_name" ||
  fatal "failed to apply updated theme"

log_info "Updated theme: $theme_name"
