#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-workspace"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/workspace.sh
source "$OMADORA_LIB_DIR/workspace.sh"

# Workspace

# ----------------------------
# Usage
# ----------------------------
usage() {
  cat <<'EOF'
Usage:
  omactl workspace <command>

Commands:
  toggle-waybar        Toggle Waybar visibility

EOF
}

# ----------------------------
# Completion
# ----------------------------
__complete() {
  local comp_words=("$@")
  local cmd="${comp_words[0]:-}"

  case "$cmd" in
  toggle-waybar)
    ;;

  *)
    compgen -W "toggle-waybar" -- "$cmd"
    ;;
  esac
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
"" | -h | --help | help)
  usage
  ;;

toggle-waybar) # TODO: Change to toggle submenu
  workspace_toggle_waybar
  ;;

__complete)
  shift
  __complete "$@"
  ;;

*)
  usage >&2
  fatal "unknown command: $cmd"
  ;;
esac
