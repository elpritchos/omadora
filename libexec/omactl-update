#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-update"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/update.sh
source "$OMADORA_LIB_DIR/update.sh"

# ----------------------------
# Usage
# ----------------------------
usage() {
  cat <<'EOF'
Usage:
  omactl update <command>

Commands:
  all (default)        Update everything (git, cargo, flatpak, etc.)
  check                Perform manual update check
  migrate              Run migrations

EOF
}

# ----------------------------
# Completion
# ----------------------------
__complete() {
  local comp_words=("$@")
  local cmd="${comp_words[0]:-}"

  case "$cmd" in
  all | check | migrate)
    ;;
  *)
    compgen -W "all check migrate" -- "$cmd"
    ;;
  esac
}

# ----------------------------
# Dispatcher
# ----------------------------
cmd="${1:-}"

case "$cmd" in
-h | --help | help)
  usage
  ;;

"" | all)
  exec "$OMADORA_LIBEXEC_DIR/omadora-update"
  ;;

check)
  exec "$OMADORA_LIBEXEC_DIR/systemd/omadora-update-check"
  ;;

migrate)
  exec "$OMADORA_LIBEXEC_DIR/omadora-update-migrate"
  ;;

__complete)
  shift
  __complete "$@"
  ;;

*)
  usage >&2
  printf 'ERROR: unknown command: %s\n' "$cmd" >&2
  exit 2
  ;;
esac
