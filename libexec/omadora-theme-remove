#!/usr/bin/env bash

set -euo pipefail

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/omadora"
# shellcheck source=../lib/theme.sh
source "$DATA_DIR/lib/theme.sh"

theme_name="${1:-}"

[[ -n "$theme_name" ]] || {
  echo "Error: Missing theme name." >&2
  exit 1
}

theme_path="${OMADORA_USER_THEMES_DIR}/$theme_name"

# Check if theme exists before attempting removal
if [ ! -d "$theme_path" ]; then
  echo "Error: Theme '$theme_name' not found."
  return 1
fi

# Now remove the theme directory for THEME_NAME
rm -rf "$theme_path"
