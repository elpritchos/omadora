#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

theme_name="${1:-}"

[[ -n "$theme_name" ]] ||
  die "missing theme name"

theme_path="${OMADORA_USER_THEMES_DIR}/$theme_name"

[[ -d "$theme_path" ]] ||
  die "theme not found: $theme_name"

current_theme_name="$(theme_current)" ||
  die "no current theme set"

if [[ "$current_theme_name" == "$theme_name" ]]; then
  die "cannot remove active theme"
fi

rm -rf "$theme_path" ||
  die "failed to remove theme: $theme_name"

info "Removed theme: $theme_name"
