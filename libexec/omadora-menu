#!/bin/bash

# Launch the Omadora Menu or takes a parameter to jump straight to a submenu.

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-a" "$index")
    fi
  fi

  echo -e "$options" | omadora-launch-wofi --dmenu --width 320 -p "$prompt…" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.omadora.terminal "$@"
}

present_terminal() {
  omadora-launch-floating-terminal-with-presentation "$1"
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  omadora-launch-editor "$1"
}

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  Omadora\n  Hyprland\n  Fedora\n󰣇  Arch\n  Neovim\n󱆃  Bash\n  Tmux") in
  *Keybindings*) omadora-menu-keybindings ;;
  *Omadora*) omadora-launch-webapp "https://github.com/elpritchos/omadora" ;;
  *Hyprland*) omadora-launch-webapp "https://wiki.hypr.land" ;;
  *Fedora*) omadora-launch-webapp "https://docs.fedoraproject.org" ;;
  *Arch*) omadora-launch-webapp "https://wiki.archlinux.org" ;;
  *Neovim*) omadora-launch-webapp "https://neovim.io/doc/user/quickref.html" ;;
  *Bash*) omadora-launch-webapp "https://devhints.io/bash" ;;
  *Tmux*) omadora-launch-webapp "https://github.com/tmux/tmux/wiki" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "󰔛  Reminder\n  Capture\n󰧸  Transcode\n  Share\n󰔎  Toggle\n  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Capture*) show_capture_menu ;;
  *Transcode*) present_terminal omadora-transcode ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "󰔛  Set one\n󰔛  Show all\n󰔛  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) omadora-reminder show ;;
  *"Clear all"*) omadora-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(
    echo -e '1\n5\n10\n15\n30\n60\n120' |
      omadora-launch-wofi --dmenu \
        --width 500 \
        --height 240 \
        --prompt "Remind in minutes"
  )

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omadora-notification-send "󰔛" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(
    echo 'Take a break...' |
      omadora-launch-wofi --dmenu \
        --width 500 \
        --height 240 \
        --prompt "Reminder message"
  )

  if [[ -n $message ]]; then
    omadora-reminder "$minutes" "$message"
  else
    back_to show_reminder_menu
  fi
}

# HACK: Sleeps added to let wofi close before screen capture
show_capture_menu() {
  case $(menu "Capture" "  Screenshot\n  Screenrecord\n󰴑  Text Extraction\n󰃉  Color") in
  *Screenshot*) sleep 0.1 && omadora-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) sleep 0.1 && omadora-capture-text-extraction ;;
  *Color*) sleep 0.1 && pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

# HACK: Sleeps added to let wofi close before screen capture
show_screenrecord_menu() {
  omadora-capture-screenrecording --stop-recording && exit 0

  case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio\n  With desktop + microphone audio + webcam") in
  *"With no audio") sleep 0.1 && omadora-capture-screenrecording ;;
  *"With desktop audio") sleep 0.1 && omadora-capture-screenrecording --with-desktop-audio ;;
  *"With desktop + microphone audio") sleep 0.1 && omadora-capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    sleep 0.1 && omadora-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File \n  Folder") in
  *Clipboard*) omadora-menu-share clipboard ;;
  *File*) terminal bash -c "omadora-menu-share file" ;;
  *Folder*) terminal bash -c "omadora-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="󱄄  Screensaver\n󰔎  Nightlight\n󱫖  Idle Lock\n󰂛  Notifications\n  Weather\n󰍜  Top Bar\n󱂬  Workspace Layout\n  Window Gaps\n  1-Window Ratio\n󰍹  Monitor Scaling"

  case $(menu "Toggle" "$options") in
  *Screensaver*) omadora-toggle-screensaver ;;
  *Nightlight*) omadora-toggle-nightlight ;;
  *Idle*) omadora-toggle-idle ;;
  *Notifications*) omadora-toggle-notification-silencing ;;
  *Weather*) omadora-toggle-weather ;;
  *Bar*) omadora-toggle-waybar ;;
  *Layout*) omadora-hyprland-workspace-layout-toggle ;;
  *Ratio*) omadora-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) omadora-hyprland-window-gaps-toggle ;;
  *Scaling*) omadora-hyprland-monitor-scaling-cycle ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  local options="󰛧  Laptop Display\n󰍹  Mirror Display"

  if omadora-hw-touchpad; then
    options="$options\n󰟸  Touchpad"
  fi

  if omadora-hw-touchscreen; then
    options="$options\n󰆽  Touchscreen"
  fi

  case $(menu "Toggle" "$options") in
  *Laptop*) omadora-hyprland-monitor-internal toggle ;;
  *Mirror*) omadora-hyprland-monitor-internal-mirror toggle ;;
  *Touchpad*) omadora-toggle-touchpad ;;
  *Touchscreen*) omadora-toggle-touchscreen ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n  Terminal Font\n  Background\n  Hyprland\n󱄄  Screensaver\n  About") in
  *Theme*) show_theme_menu ;;
  *"Terminal Font"*) show_font_menu ;;
  *Background*) omactl theme bg-next ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_about_menu() {
  case $(menu "About" "  Edit Text\n  Set From Image\n  Restore Default") in
  *Text*) omadora-branding-about text ;;
  *Image*) omadora-branding-about image ;;
  *Default*) omadora-branding-about reset ;;
  *) show_style_menu ;;
  esac
}

show_screensaver_menu() {
  case $(menu "Screensaver" "  Edit Text\n  Set From Image\n  Restore Default") in
  *Text*) omadora-branding-screensaver text ;;
  *Image*) omadora-branding-screensaver image ;;
  *Default*) omadora-branding-screensaver reset ;;
  *) show_style_menu ;;
  esac
}

show_theme_menu() {
  theme=$(menu "Theme" "$(omactl theme list)" "" "$(omactl theme current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    omactl theme set "$theme"
  fi
}

show_font_menu() {
  theme=$(menu "Font" "$(omadora-font-list)" "--width 350" "$(omadora-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    omadora-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile\n󰍹  Monitors"
  [ -f ~/.config/hypr/bindings.conf ] && options="$options\n  Keybindings"
  [ -f ~/.config/hypr/input.conf ] && options="$options\n󰍽  Input"
  options="$options\n  Security\n  Config"

  case $(menu "Setup" "$options") in
  *Audio*) omadora-launch-audio ;;
  *Wifi*) omadora-launch-wifi ;;
  *Bluetooth*) omadora-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(omadora-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    omadora-powerprofiles-set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "󰈷  Fingerprint\n  Fido2") in
  *Fingerprint*) present_terminal omadora-setup-security-fingerprint ;;
  *Fido2*) present_terminal omadora-setup-security-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "  Hyprland\n  Hypridle\n  Hyprlock\n  Hyprsunset\n󰌧  Wofi\n󰍜  Waybar\n󰞅  XCompose") in
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && omadora-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && omadora-restart-hyprsunset ;;
  *Wofi*) open_in_editor ~/.config/wofi/config ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omadora-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && omadora-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "  Package\n  Web App\n  TUI\n  Style") in
  *Package*) terminal omadora-pkg-install ;;
  *Web*) present_terminal omadora-webapp-install ;;
  *TUI*) present_terminal omadora-tui-install ;;
  *Style*) show_install_style_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "󰸌  Theme\n  Background") in
  *Theme*) present_terminal 'omactl theme add "$(gum input --placeholder="https://github.com/..." --header="Install user theme from repo URL:")"' ;;
  *Background*)
    theme="$(omactl theme current)"
    if [ -z "$theme" ]; then
      notify-send "No active theme" "Set a theme before adding backgrounds"
    else
      dir="$HOME/.config/omadora/backgrounds/$theme"
      mkdir -p "$dir" && nautilus "$dir"
    fi
    ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  case $(menu "Remove" "  Package\n  Web App\n  TUI\n󰸌  Theme\n  Security") in
  *Package*) terminal omadora-pkg-remove ;;
  *Web*) present_terminal omadora-webapp-remove ;;
  *TUI*) present_terminal omadora-tui-remove ;;
  *Theme*) present_terminal 'omactl theme remove "$(omactl theme list-user | gum choose --header="Remove user theme:")"' ;;
  *Security*) show_remove_security_menu ;;
  *) show_main_menu ;;
  esac
}

show_remove_security_menu() {
  case $(menu "Remove" "󰈷  Fingerprint\n  Fido2") in
  *Fingerprint*) present_terminal omadora-remove-security-fingerprint ;;
  *Fido2*) present_terminal omadora-remove-security-fido2 ;;
  *) show_remove_menu ;;
  esac
}

show_update_menu() {
  case $(menu "Update" "  Omadora\n  Config\n󰸌  Theme\n  Process\n󰇅  Hardware\n  Password\n  Timezone") in
  *Omadora*) present_terminal 'omactl update' ;;
  *Config*) show_update_config_menu ;;
  *Theme*) present_terminal 'omactl theme update "$(omactl theme list-user | gum choose --header="Update user theme:")"' ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Timezone*) present_terminal omadora-tz-select ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_process_menu() {
  case $(menu "Restart" "  Hypridle\n  Hyprsunset\n󰎟  Mako\n󰍜  Waybar") in
  *Hypridle*) omadora-restart-hypridle ;;
  *Hyprsunset*) omadora-restart-hyprsunset ;;
  *Mako*) omadora-restart-mako ;;
  *Waybar*) omadora-restart-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "  Hyprland\n  Hypridle\n  Hyprlock\n  Hyprsunset\n󱣴  Plymouth\n  Tmux\n󰌧  Wofi\n󰍜  Waybar") in
  *Hyprland*) present_terminal omadora-refresh-hyprland ;;
  *Hypridle*) present_terminal omadora-refresh-hypridle ;;
  *Hyprlock*) present_terminal omadora-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal omadora-refresh-hyprsunset ;;
  *Plymouth*) present_terminal omadora-refresh-plymouth ;;
  *Tmux*) present_terminal omadora-refresh-tmux ;;
  *Wofi*) present_terminal omadora-refresh-wofi ;;
  *Waybar*) present_terminal omadora-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "  Audio\n󱚾  Wi-Fi\n󰂯  Bluetooth") in
  *Audio*) present_terminal omadora-restart-pipewire ;;
  *Wi-Fi*) present_terminal omadora-restart-wifi ;;
  *Bluetooth*) present_terminal omadora-restart-bluetooth ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "  Drive Encryption\n  User") in
  *Drive*) present_terminal omadora-drive-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  omadora-launch-about
}

show_system_menu() {
  case $(menu "System" "  Lock\n󱄄  Screensaver\n󰍃  Logout\n󰜉  Reboot\n󰐥  Shutdown") in
  *Lock*) omactl system lock ;;
  *Screensaver*) omactl system screensaver ;;
  *Logout*) omactl system logout ;;
  *Reboot*) omactl system reboot ;;
  *Shutdown*) omactl system shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "󰀻  Apps\n󰧑  Learn\n󱓞  Trigger\n  Style\n  Setup\n󰉉  Install\n󰭌  Remove\n  Update\n  About\n  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) omadora-launch-wofi --show drun -p "Launch…" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *hardware*) show_hardware_menu ;;
  *share*) show_share_menu ;;
  *reminder-set*) show_custom_reminder_input ;;
  *reminder*) show_reminder_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omadora/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
