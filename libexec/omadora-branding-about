#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Edit, set, or reset About branding

set -euo pipefail

case "${1:-}" in
image)
  image=$(omadora_run omadora-menu-file "Logo image" "$HOME" "svg png")
  if [[ -n $image ]] && omadora_run omadora-transcode-ascii "$image" ~/.config/omadora/branding/about.txt --width 54 --height 26 --mode block; then
    omadora_run omadora-launch-about >/dev/null 2>&1
  fi
  ;;
text)
  omadora_run omadora-launch-editor ~/.config/omadora/branding/about.txt >/dev/null 2>&1 && omadora_run omadora-launch-about >/dev/null 2>&1
  ;;
reset)
  cp "$OMADORA_PATH/icon.txt" ~/.config/omadora/branding/about.txt && omadora_run omadora-launch-about >/dev/null 2>&1
  ;;
*)
  echo "Usage: omadora-branding-about <image|text|reset>" >&2
  exit 1
  ;;
esac
