#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

theme_name="$(theme_name_normalize "${1:-}")"

if [[ -d "$OMADORA_USER_THEMES_DIR/$theme_name" ]]; then
  theme_path="$OMADORA_USER_THEMES_DIR/$theme_name"
elif [[ -d "$OMADORA_THEMES_DIR/$theme_name" ]]; then
  theme_path="$OMADORA_THEMES_DIR/$theme_name"
else
  echo "Error: Theme '$theme_name' does not exist."
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$OMADORA_NEXT_THEME_DIR"
mkdir -p "$OMADORA_NEXT_THEME_DIR"

# Copy static configs
cp -r "$theme_path/." "$OMADORA_NEXT_THEME_DIR/" 2>/dev/null

# Generate dynamic configs
theme_set_templates

# Swap next theme in as current
rm -rf "$OMADORA_CURRENT_THEME_DIR"
mv "$OMADORA_NEXT_THEME_DIR" "$OMADORA_CURRENT_THEME_DIR"

# Store theme name for reference
# Theme component configs reloaded by omadora-theme.service watching this file
echo "$theme_name" >"${OMADORA_THEME_NAME_FILE}"

# Change background with theme
"$OMADORA_LIBEXEC_DIR/omadora-theme-bg-next"

# Change app-specific themes
theme_set_gnome

# Call hook on theme set
omadora-hook theme-set "$theme_name" # TODO: Move to libexec
