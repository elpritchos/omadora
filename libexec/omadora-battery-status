#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Returns a formatted battery status string with percentage and power draw/charge.

battery_info=$(upower -i "$(upower -e | grep BAT)")

percentage=$(echo "$battery_info" | awk '/percentage/ {
    print int($2)
    exit
}')

power_rate=$(echo "$battery_info" | awk '/energy-rate/ {
    rounded = sprintf("%.1f", $2)
    sub(/¥.0$/, "", rounded)
    print rounded
    exit
}')

state=$(echo "$battery_info" | awk '/state/ { print $2; exit }')
time_remaining=$(omadora_run omadora-battery-remaining-time)
capacity=$(omadora_run omadora-battery-capacity)

if [[ $state == "charging" ]]; then
  echo "㬚∋    Battery ${percentage}% ﾂｷ ${time_remaining} to full ﾂｷ 雒｢ ${power_rate}W / ${capacity}Wh"
else
  echo "㬚∋    Battery ${percentage}% ﾂｷ ${time_remaining} left ﾂｷ 雒｣ ${power_rate}W / ${capacity}Wh"
fi
