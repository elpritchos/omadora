#!/usr/bin/env bash

set -Eeuo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/omadora/update"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omadora/update"
RUNTIME_DIR="${XDG_RUNTIME_DIR:?}/omadora/update"

STATE_FILE="$STATE_DIR/state.json"

mkdir -p \
  "$STATE_DIR" \
  "$CACHE_DIR" \
  "$RUNTIME_DIR"

# -----------------------------------------------------------------------------
# Locking
# -----------------------------------------------------------------------------

exec 9>"$RUNTIME_DIR/update.lock"

# Exit silently if another check/update is already running
flock -n 9 || exit 0

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

timestamp() {
  date +%s
}

write_json_atomic() {
  local target="$1"
  local tmp

  tmp="$(mktemp "${target}.tmp.XXXXXX")"

  cat >"$tmp"

  mv "$tmp" "$target"
}

# -----------------------------------------------------------------------------
# Initial State
# -----------------------------------------------------------------------------

now="$(timestamp)"

dnf_advisory_total=0
dnf_security_total=0
dnf_bugfix_total=0
dnf_enhancement_total=0
dnf_other_total=0
dnf_package_total=0

flatpak_total=0
firmware_total=0
cargo_total=0

restart_required=false

# -----------------------------------------------------------------------------
# DNF Updates
# -----------------------------------------------------------------------------

DNF_JSON="$CACHE_DIR/dnf-update-advisories.json"

if dnf5 advisory info --updates --json \
  >"$DNF_JSON" 2>/dev/null; then

  # Total advisories
  dnf_advisory_total="$(
    jq 'keys | length' "$DNF_JSON"
  )"

  # Security advisories
  dnf_security_total="$(
    jq '
      [
        .[]
        | select(.Type == "security")
      ] | length
    ' "$DNF_JSON"
  )"

  # Bugfix advisories
  dnf_bugfix_total="$(
    jq '
      [
        .[]
        | select(.Type == "bugfix")
      ] | length
    ' "$DNF_JSON"
  )"

  # Enhancement advisories
  dnf_enhancement_total="$(
    jq '
      [
        .[]
        | select(.Type == "enhancement")
      ] | length
    ' "$DNF_JSON"
  )"

  dnf_other_total="$(
    jq '
      [
        .[]
        | select(
            .Type != "security" and
            .Type != "bugfix" and
            .Type != "enhancement"
          )
      ]
      | length
    ' "$DNF_JSON"
  )"

  # Meaningful package update count
  dnf_package_total="$(
    jq '
      [
        .[]
        | .Title
        | capture("^(?<name>.+)-[0-9]")
        | .name
      ]
      | unique
      | length
    ' "$DNF_JSON"
  )"
fi

# -----------------------------------------------------------------------------
# Flatpak Updates
# -----------------------------------------------------------------------------

if command -v flatpak >/dev/null 2>&1; then
  flatpak_total="$(
    flatpak remote-ls \
      --updates \
      --columns=ref \
      2>/dev/null |
      grep -Ec '^[a-zA-Z0-9._-]+/.+/.+/.+'
  )"
fi

## -----------------------------------------------------------------------------
## Firmware Updates
## -----------------------------------------------------------------------------
#
#FWUPD_JSON="$CACHE_DIR/fwupd.json"
#
#if command -v fwupdmgr >/dev/null 2>&1; then
#  if fwupdmgr get-updates --json \
#    > "$FWUPD_JSON" 2>/dev/null; then
#
#    firmware_total="$(
#      jq '
#        [
#          .Devices[]?
#          | select(
#              .Updates != null and
#              (.Updates | length > 0)
#            )
#        ]
#        | length
#      ' "$FWUPD_JSON"
#    )"
#  fi
#fi
#
## -----------------------------------------------------------------------------
## Cargo Updates
## -----------------------------------------------------------------------------
#
#if command -v cargo-install-update >/dev/null 2>&1; then
#  cargo_total="$(
#    cargo-install-update -l 2>/dev/null \
#      | tail -n +2 \
#      | grep -cve '^[[:space:]]*$' || true
#  )"
#fi
#
## -----------------------------------------------------------------------------
## Restart Detection
## -----------------------------------------------------------------------------
#
## needs-restarting:
##   exit 0 = no reboot required
##   exit 1 = reboot required
#
#if command -v needs-restarting >/dev/null 2>&1; then
#  if ! needs-restarting -r >/dev/null 2>&1; then
#    restart_required=true
#  fi
#fi

# -----------------------------------------------------------------------------
# Aggregate Totals
# -----------------------------------------------------------------------------

total_updates=$((\
  dnf_package_total + \
  flatpak_total + \
  firmware_total + \
  cargo_total))

# -----------------------------------------------------------------------------
# Write Normalized State
# -----------------------------------------------------------------------------

jq -n \
  --argjson timestamp "$now" \
  --argjson dnf_advisory_total "$dnf_advisory_total" \
  --argjson dnf_security_total "$dnf_security_total" \
  --argjson dnf_bugfix_total "$dnf_bugfix_total" \
  --argjson dnf_enhancement_total "$dnf_enhancement_total" \
  --argjson dnf_other_total "$dnf_other_total" \
  --argjson dnf_package_total "$dnf_package_total" \
  --argjson flatpak_total "$flatpak_total" \
  --argjson firmware_total "$firmware_total" \
  --argjson cargo_total "$cargo_total" \
  --argjson total_updates "$total_updates" \
  --argjson restart_required "$restart_required" \
  '
{
  schema_version: 1,

  timestamp: $timestamp,

  updates: {
    dnf: {
      advisories: {
        total: $dnf_advisory_total,
        security: $dnf_security_total,
        bugfix: $dnf_bugfix_total,
        enhancement: $dnf_enhancement_total,
        other: $dnf_other_total
      },

      packages: {
        total: $dnf_package_total
      }
    },

    flatpak: {
      count: $flatpak_total
    },

    firmware: {
      count: $firmware_total
    },

    cargo: {
      count: $cargo_total
    }
  },

  total_updates: $total_updates,

  restart_required: $restart_required
}
' | write_json_atomic "$STATE_FILE"
