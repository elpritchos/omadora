#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

mkdir -p \
  "$OMADORA_STATE_HOME" \
  "$OMADORA_CACHE_HOME" \
  "$OMADORA_RUNTIME_DIR"

STATE_FILE="$OMADORA_STATE_HOME/state.json"

# -----------------------------------------------------------------------------
# Locking
# -----------------------------------------------------------------------------

exec 9>"$OMADORA_RUNTIME_DIR/update.lock"

# Exit silently if another check/update is already running
flock -n 9 || exit 0

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

timestamp() {
  date +%s
}

write_json_atomic() {
  local target="$1"
  local tmp

  tmp="$(mktemp "${target}.tmp.XXXXXX")"

  cat >"$tmp"

  mv "$tmp" "$target"
}

# -----------------------------------------------------------------------------
# Initial State
# -----------------------------------------------------------------------------

now="$(timestamp)"

dnf_advisory_total=0
dnf_security_total=0
dnf_bugfix_total=0
dnf_enhancement_total=0
dnf_other_total=0
dnf_package_total=0

flatpak_total=0
firmware_total=0
cargo_total=0

restart_required=false

# -----------------------------------------------------------------------------
# DNF Updates
# -----------------------------------------------------------------------------

DNF_UPGRADES_LIST="$OMADORA_CACHE_HOME/dnf-upgrades.txt"

if dnf5 repoquery \
  --upgrades \
  >"$DNF_UPGRADES_LIST" 2>/dev/null; then

  dnf_package_total="$(
    wc -l <"$DNF_UPGRADES_LIST"
  )"
fi

DNF_ADVISORIES_JSON="$OMADORA_CACHE_HOME/dnf-advisories.json"

if dnf5 advisory info --json \
  >"$DNF_ADVISORIES_JSON" 2>/dev/null; then

  # Total advisories
  dnf_advisory_total="$(
    jq 'keys | length' "$DNF_ADVISORIES_JSON"
  )"

  # Security advisories
  dnf_security_total="$(
    jq '
      [
        .[]
        | select(.Type == "security")
      ] | length
    ' "$DNF_ADVISORIES_JSON"
  )"

  # Bugfix advisories
  dnf_bugfix_total="$(
    jq '
      [
        .[]
        | select(.Type == "bugfix")
      ] | length
    ' "$DNF_ADVISORIES_JSON"
  )"

  # Enhancement advisories
  dnf_enhancement_total="$(
    jq '
      [
        .[]
        | select(.Type == "enhancement")
      ] | length
    ' "$DNF_ADVISORIES_JSON"
  )"

  # Other advisories
  dnf_other_total="$(
    jq '
      [
        .[]
        | select(
            .Type != "security" and
            .Type != "bugfix" and
            .Type != "enhancement"
          )
      ]
      | length
    ' "$DNF_ADVISORIES_JSON"
  )"
fi

# -----------------------------------------------------------------------------
# Flatpak Updates
# -----------------------------------------------------------------------------

if command -v flatpak >/dev/null 2>&1; then
  flatpak_total="$(
    flatpak remote-ls \
      --updates \
      --columns=ref \
      2>/dev/null |
      grep -Ec '^[a-zA-Z0-9._-]+/.+/.+/.+'
  )"
fi

# -----------------------------------------------------------------------------
# Firmware Updates
# -----------------------------------------------------------------------------

FWUPD_JSON="$OMADORA_CACHE_HOME/fwupd.json"

if command -v fwupdmgr >/dev/null 2>&1; then
  if fwupdmgr get-updates --json \
    >"$FWUPD_JSON" 2>/dev/null; then

    firmware_total="$(
      jq '
        [
          .Devices[]?
          | select(
              .Updates != null and
              (.Updates | length > 0)
            )
        ]
        | length
      ' "$FWUPD_JSON"
    )"
  fi
fi

## -----------------------------------------------------------------------------
## Cargo Updates
## -----------------------------------------------------------------------------
#
#if command -v cargo-install-update >/dev/null 2>&1; then
#  cargo_total="$(
#    cargo-install-update -l 2>/dev/null \
#      | tail -n +2 \
#      | grep -cve '^[[:space:]]*$' || true
#  )"
#fi
#
## -----------------------------------------------------------------------------
## Restart Detection
## -----------------------------------------------------------------------------
#
## needs-restarting:
##   exit 0 = no reboot required
##   exit 1 = reboot required
#
#if command -v needs-restarting >/dev/null 2>&1; then
#  if ! needs-restarting -r >/dev/null 2>&1; then
#    restart_required=true
#  fi
#fi

# -----------------------------------------------------------------------------
# Aggregate Totals
# -----------------------------------------------------------------------------

total_updates=$((\
  dnf_package_total + \
  flatpak_total + \
  firmware_total + \
  cargo_total))

# -----------------------------------------------------------------------------
# Write Normalized State
# -----------------------------------------------------------------------------

jq -n \
  --argjson timestamp "$now" \
  --argjson total_updates "$total_updates" \
  --argjson restart_required "$restart_required" \
  --argjson dnf_package_total "$dnf_package_total" \
  --argjson flatpak_total "$flatpak_total" \
  --argjson cargo_total "$cargo_total" \
  --argjson firmware_total "$firmware_total" \
  --argjson dnf_advisory_total "$dnf_advisory_total" \
  --argjson dnf_security_total "$dnf_security_total" \
  --argjson dnf_bugfix_total "$dnf_bugfix_total" \
  --argjson dnf_enhancement_total "$dnf_enhancement_total" \
  --argjson dnf_other_total "$dnf_other_total" \
  '
{
  schema_version: 1,

  timestamp: $timestamp,

  updates: {

    total: $total_updates,

    dnf: {
      count: $dnf_package_total
    },

    flatpak: {
      count: $flatpak_total
    },

    cargo: {
      count: $cargo_total
    },

    firmware: {
      count: $firmware_total
    }
  },

  advisories: {
    dnf: {
      total: $dnf_advisory_total,
      security: $dnf_security_total,
      bugfix: $dnf_bugfix_total,
      enhancement: $dnf_enhancement_total,
      other: $dnf_other_total
    },
  },

  restart_required: $restart_required

}
' | write_json_atomic "$STATE_FILE"

cat <"$STATE_FILE"
