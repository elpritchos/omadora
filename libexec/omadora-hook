#!/bin/bash

# Run a named hook from ~/.config/omadora/hooks/<name> and ~/.config/omadora/hooks/<name>.d/.

set -e

if (($# < 1)); then
  echo "Usage: omadora-hook [name] [args...]"
  exit 1
fi

HOOK=$1
HOOK_PATH="$HOME/.config/omadora/hooks/$HOOK"
HOOK_DIR="$HOOK_PATH.d"
shift

if [[ -f $HOOK_PATH ]]; then
  bash "$HOOK_PATH" "$@" || echo "Hook failed: $HOOK_PATH"
fi

if [[ -d $HOOK_DIR ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -f $hook ]] || continue
    [[ $hook == *.sample ]] && continue
    bash "$hook" "$@" || echo "Hook failed: $hook"
  done
fi
