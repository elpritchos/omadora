#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

image_path="${1:-}"
current_theme_name=$(theme_current) || exit 1

[[ -n "$image_path" ]] || {
  echo "Error: Missing image path." >&2
  exit 1
}

[[ -f "$image_path" ]] || {
  echo "Error: Invalid image path: $image_path" >&2
  exit 1
}

dest_dir="${OMADORA_USER_BACKGROUNDS_DIR}/${current_theme_name}"
mkdir -p "$dest_dir"

cp "$image_path" "$dest_dir/"

ln -nsf "$dest_dir/$(basename "$image_path")" "$OMADORA_CURRENT_BACKGROUND_LINK"
