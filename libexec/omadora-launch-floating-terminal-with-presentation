#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Launch a floating terminal with the Omadora presentation wrapper

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.omadora.terminal --title=Omadora -- bash -c "$(omadora_command omadora-show-logo); $cmd; status=\$?; if (( status != 130 )); then $(omadora_command omadora-show-done); fi; exit \"\$status\""
