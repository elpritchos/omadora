#!/usr/bin/env bash
set -euo pipefail

readonly OMADORA_LOG_TAG="omadora-update"

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../../lib/common/init.sh"

# shellcheck source=lib/update.sh
source "$OMADORA_LIB_DIR/update.sh"

require_cmd dnf5
require_cmd jq

update_dirs_init ||
  fatal "failed to initialize update dirs"

# -----------------------------------------------------------------------------
# Locking
# -----------------------------------------------------------------------------
exec 9>"$OMADORA_UPDATE_LOCK_FILE"

# Exit silently if another check/update is already running
flock -n 9 || exit 0

# -----------------------------------------------------------------------------
# Update Check Workflow
# -----------------------------------------------------------------------------

printf 'Update check started\n'
log_info "Starting update check"

printf 'Collecting dnf updates\n'
update_collect_dnf ||
  fatal "failed to collect dnf updates"

printf 'Collecting cargo updates\n'
update_collect_cargo ||
  fatal "failed to collect cargo updates"

printf 'Collecting flatpak updates\n'
update_collect_flatpak ||
  fatal "failed to collect flatpak updates"

printf 'Collecting firmware updates\n'
update_collect_firmware ||
  fatal "failed to collect firmware updates"

printf 'Writing update state\n'
update_write_state ||
  fatal "failed to write update state"

printf 'Updating waybar module\n'
update_waybar_module ||
  log_debug "Failed to update Waybar module"

printf 'Update check complete\n'
log_info "Update check complete"
