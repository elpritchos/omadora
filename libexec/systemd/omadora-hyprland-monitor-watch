#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../../lib/common/init.sh"

# Watch Hyprland monitor events and recover monitor toggles when a monitor is removed

SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"

socat -U - "UNIX-CONNECT:$SOCKET" | while read -r event; do
  case "$event" in
  monitorremovedv2\>\>*)
    omadora_run omadora-hyprland-monitor-internal recover
    omadora_run omadora-hyprland-monitor-internal-mirror recover
    ;;
  monitoraddedv2\>\>*)
    # HACK: Temporary fix for multiple waybar issues with external monitors
    if systemctl --quiet --user is-active waybar.service; then
      (sleep 0.1 && systemctl --quiet --user restart waybar.service)
    fi
    ;;
  esac
done
