[Unit]
Description=Omadora Weather Check Service
After=graphical-session.target network-online.target

[Service]
Type=oneshot
ExecStart=%h/.local/share/omadora/libexec/systemd/omadora-weather-check

# hardening (safe, minimal)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=false

# allow writing state/cache
ReadWritePaths=%h/.local/state/omadora/weather %h/.cache/omadora/weather

Nice=10
TimeoutStartSec=5m
