# Changes require a restart to take effect.

# Cursor size
export XCURSOR_SIZE=24
export HYPRCURSOR_SIZE=24

# Force all apps to use Wayland
export GDK_BACKEND="wayland,x11,*"
export QT_QPA_PLATFORM="wayland;xcb"
export QT_STYLE_OVERRIDE="kvantum"
export SDL_VIDEODRIVER="wayland"
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT="wayland"
export OZONE_PLATFORM="wayland"
export XDG_SESSION_TYPE="wayland"

# Allow better support for screen sharing (Google Meet, Discord, etc)
export XDG_CURRENT_DESKTOP="Hyprland"
export XDG_SESSION_DESKTOP="Hyprland"

# Use XCompose file
export XCOMPOSEFILE=$HOME/.XCompose

# Gum Style Variables
# 14 = informational / headers / prompts
# 12 = current focus / cursor / active indicator
# 10 = selected
# 7  = normal text
# 8  = secondary text
export GUM_CHOOSE_CURSOR_FOREGROUND="12"
export GUM_CHOOSE_HEADER_FOREGROUND="14"
export GUM_CHOOSE_SELECTED_FOREGROUND="10"

export GUM_CONFIRM_PROMPT_FOREGROUND="14"
export GUM_CONFIRM_SELECTED_FOREGROUND="0"
export GUM_CONFIRM_SELECTED_BACKGROUND="10"
export GUM_CONFIRM_UNSELECTED_FOREGROUND="7"
export GUM_CONFIRM_UNSELECTED_BACKGROUND="0"

export GUM_FILTER_INDICATOR_FOREGROUND="12"
export GUM_FILTER_SELECTED_PREFIX_FOREGROUND="10"
export GUM_FILTER_UNSELECTED_PREFIX_FOREGROUND="8"
export GUM_FILTER_HEADER_FOREGROUND="14"
export GUM_FILTER_MATCH_FOREGROUND="14"
export GUM_FILTER_PROMPT_FOREGROUND="14"
export GUM_FILTER_PLACEHOLDER_FOREGROUND="8"

export GUM_FILE_CURSOR_FOREGROUND="14"
export GUM_FILE_SYMLINK_FOREGROUND="6"      # or 14 if you want bright variants only
export GUM_FILE_DIRECTORY_FOREGROUND="12"
export GUM_FILE_PERMISSIONS_FOREGROUND="8"
export GUM_FILE_SELECTED_FOREGROUND="10"
export GUM_FILE_FILE_SIZE_FOREGROUND="8"
export GUM_FILE_HEADER_FOREGROUND="14"

export GUM_INPUT_PLACEHOLDER_FOREGROUND="8"
export GUM_INPUT_CURSOR_FOREGROUND="12"
export GUM_INPUT_HEADER_FOREGROUND="14"

export GUM_PAGER_LINE_NUMBER_FOREGROUND="8"
export GUM_PAGER_MATCH_FOREGROUND="14"
export GUM_PAGER_MATCH_HIGH_FOREGROUND="0"
export GUM_PAGER_MATCH_HIGH_BACKGROUND="12"
export GUM_PAGER_HELP_FOREGROUND="8"

export GUM_SPIN_SPINNER_FOREGROUND="12"

export GUM_TABLE_SELECTED_FOREGROUND="12"

export GUM_WRITE_CURSOR_LINE_NUMBER_FOREGROUND="12"
export GUM_WRITE_CURSOR_FOREGROUND="12"
export GUM_WRITE_END_OF_BUFFER_FOREGROUND="8"
export GUM_WRITE_LINE_NUMBER_FOREGROUND="8"
export GUM_WRITE_HEADER_FOREGROUND="14"
export GUM_WRITE_PLACEHOLDER_FOREGROUND="8"
export GUM_WRITE_PROMPT_FOREGROUND="14"

# Set default terminal and editor
source ~/.config/uwsm/default
